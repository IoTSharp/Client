<atom:Window xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:atom="https://atomui.net"
             xmlns:vm="using:IoTSharp.Client.ViewModels"
             xmlns:models="using:IoTSharp.Client.Models"
             mc:Ignorable="d"
             x:Class="IoTSharp.Client.Views.MainWindow"
             x:DataType="vm:MainWindowViewModel"
             Width="1440"
             Height="920"
             MinWidth="1200"
             MinHeight="760"
             Title="IoTSharp AtomUI Client">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*" Background="#F3F4F6">
    <Border Padding="24,18" Background="#0F172A">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
        <StackPanel>
          <TextBlock Text="IoTSharp AtomUI Client" FontSize="26" FontWeight="Bold" Foreground="White" />
          <TextBlock Text="面向 IoTSharp/IoTSharp 的轻量桌面客户端，支持登录、设备属性、最新遥测和聚合数据查询。"
                     Foreground="#CBD5E1"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <ProgressBar Width="140" IsIndeterminate="True" IsVisible="{Binding IsBusy}" />
          <TextBlock Text="{Binding CurrentSessionText}" Foreground="White" VerticalAlignment="Center" IsVisible="{Binding ShowWorkspace}" />
          <atom:Button Content="退出登录" Command="{Binding LogoutCommand}" IsVisible="{Binding ShowWorkspace}" />
        </StackPanel>

        <Border Grid.Row="1" Grid.ColumnSpan="2" CornerRadius="8" Padding="12,10" Background="#1E293B">
          <TextBlock Text="{Binding StatusMessage}" Foreground="#E2E8F0" TextWrapping="Wrap" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="18" ColumnDefinitions="380,*" ColumnSpacing="18">
      <Border Grid.Column="0"
              Padding="20"
              CornerRadius="18"
              Background="White"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              IsVisible="{Binding ShowLoginPanel}">
        <ScrollViewer>
          <StackPanel Spacing="14">
            <TextBlock Text="登录 IoTSharp" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="输入服务地址、账号密码，并完成 IoTSharp 拼图验证码。" Foreground="#64748B" TextWrapping="Wrap" />

            <StackPanel Spacing="6">
              <TextBlock Text="服务地址" FontWeight="SemiBold" />
              <TextBox Text="{Binding ServerUrl, Mode=TwoWay}" Watermark="http://localhost:5000" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="用户名" FontWeight="SemiBold" />
              <TextBox Text="{Binding UserName, Mode=TwoWay}" Watermark="admin@example.com" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="密码" FontWeight="SemiBold" />
              <TextBox Text="{Binding Password, Mode=TwoWay}" Watermark="请输入密码" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Text="滑块验证码" FontWeight="SemiBold" />
              <Border CornerRadius="12" BorderBrush="#CBD5E1" BorderThickness="1" Background="#0F172A" Padding="10">
                <Canvas Width="{Binding CaptchaCanvasWidth}" Height="{Binding CaptchaCanvasHeight}">
                  <Image Width="{Binding CaptchaCanvasWidth}" Height="{Binding CaptchaCanvasHeight}" Source="{Binding CaptchaBackgroundImage}" Stretch="Fill" />
                  <Image Canvas.Left="{Binding CaptchaMove}"
                         Canvas.Top="{Binding CaptchaYOffset}"
                         Source="{Binding CaptchaPieceImage}" />
                </Canvas>
              </Border>
              <Slider Minimum="0" Maximum="{Binding CaptchaMaxOffset}" Value="{Binding CaptchaMove, Mode=TwoWay}" />
              <TextBlock Text="拖动上方拼图块到缺口位置后再登录。" Foreground="#64748B" TextWrapping="Wrap" />
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="12">
              <atom:Button Content="刷新验证码" Command="{Binding RefreshCaptchaCommand}" />
              <atom:Button Content="登录" Command="{Binding LoginCommand}" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Border Grid.Column="1"
              Padding="28"
              CornerRadius="18"
              Background="White"
              BorderBrush="#E2E8F0"
              BorderThickness="1"
              IsVisible="{Binding ShowLoginPanel}">
        <StackPanel Spacing="18">
          <TextBlock Text="客户端功能概览" FontSize="24" FontWeight="Bold" />
          <TextBlock Text="本次重构将旧 MAUI 项目替换为 Avalonia + AtomUI 桌面客户端，并聚焦 IoTSharp 核心运维场景。"
                     TextWrapping="Wrap"
                     Foreground="#475569" />

          <Border Background="#F8FAFC" CornerRadius="14" Padding="18">
            <StackPanel Spacing="10">
              <TextBlock Text="已支持能力" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="• 登录 IoTSharp 并处理服务端滑块验证码" />
              <TextBlock Text="• 获取当前用户、客户和租户上下文" />
              <TextBlock Text="• 按客户查询设备列表，并支持设备名搜索" />
              <TextBlock Text="• 查看设备属性、最新遥测、聚合遥测结果" />
            </StackPanel>
          </Border>

          <Border Background="#F8FAFC" CornerRadius="14" Padding="18">
            <StackPanel Spacing="10">
              <TextBlock Text="聚合查询示例" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Text="输入 keys、开始结束时间、采样间隔 every，再选择 Mean/Max/Min/Sum 等聚合方式即可。"
                         TextWrapping="Wrap" />
              <TextBlock Text="例如：keys = temp,humidity；every = 00:05:00；aggregate = Mean" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.ColumnSpan="2"
              Padding="18"
              CornerRadius="18"
              Background="Transparent"
              IsVisible="{Binding ShowWorkspace}">
        <Grid ColumnDefinitions="360,*" ColumnSpacing="18">
          <Border Grid.Column="0" Padding="18" CornerRadius="18" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
              <StackPanel>
                <TextBlock Text="设备浏览" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="支持按名称筛选，并优先展示在线设备。" Foreground="#64748B" />
              </StackPanel>

              <StackPanel Grid.Row="1" Spacing="10">
                <TextBox Text="{Binding DeviceSearchText, Mode=TwoWay}" Watermark="设备名称或 GUID" />
                <CheckBox IsChecked="{Binding OnlyActiveDevices, Mode=TwoWay}" Content="仅显示在线设备" />
                <atom:Button Content="刷新设备列表" Command="{Binding LoadDevicesCommand}" />
              </StackPanel>

              <ListBox Grid.Row="2"
                       ItemsSource="{Binding Devices}"
                       SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                       BorderThickness="0"
                       Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:DeviceSummary">
                    <Border Margin="0,0,0,10" Padding="12" CornerRadius="12" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="{Binding Subtitle}" Foreground="#64748B" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="状态：" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding ActiveLabel}" Foreground="#2563EB" />
                        </StackPanel>
                        <TextBlock Text="{Binding LastActivityText}" Foreground="#94A3B8" FontSize="12" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>

          <Grid Grid.Column="1" RowDefinitions="Auto,*,*" RowSpacing="18">
            <Border Padding="18" CornerRadius="18" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
              <Grid ColumnDefinitions="2*,*,*,*" ColumnSpacing="18">
                <StackPanel>
                  <TextBlock Text="{Binding SelectedDeviceDetail.Name}" FontSize="24" FontWeight="Bold" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.IdentitySummary}" Foreground="#64748B" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                  <TextBlock Text="客户 / 租户" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.CustomerName}" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.TenantName}" Foreground="#64748B" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                  <TextBlock Text="设备状态" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.ActivityText}" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.LastActivityText}" Foreground="#64748B" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                  <TextBlock Text="其它信息" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.DeviceType}" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.Owner}" Foreground="#64748B" />
                  <TextBlock Text="{Binding SelectedDeviceDetail.Timeout, StringFormat='超时: {0}s'}" Foreground="#64748B" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Row="1" Padding="18" CornerRadius="18" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
              <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                <TextBlock Text="设备属性" FontSize="20" FontWeight="Bold" />
                <Grid Grid.Row="1" ColumnDefinitions="2*,*,2*" Margin="0,4,0,0">
                  <TextBlock Text="键" FontWeight="SemiBold" Foreground="#64748B" />
                  <TextBlock Grid.Column="1" Text="类型" FontWeight="SemiBold" Foreground="#64748B" />
                  <TextBlock Grid.Column="2" Text="值 / 时间" FontWeight="SemiBold" Foreground="#64748B" />
                </Grid>
                <ScrollViewer Grid.Row="2">
                  <ItemsControl ItemsSource="{Binding Attributes}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="models:DataValueItem">
                        <Grid ColumnDefinitions="2*,*,2*" Margin="0,0,0,8">
                          <TextBlock Text="{Binding KeyName}" />
                          <TextBlock Grid.Column="1" Text="{Binding DataType}" Foreground="#64748B" />
                          <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding TimestampText}" Foreground="#94A3B8" FontSize="12" />
                          </StackPanel>
                        </Grid>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="18">
              <Border Grid.Column="0" Padding="18" CornerRadius="18" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
                  <TextBlock Text="最新遥测" FontSize="20" FontWeight="Bold" />
                  <Grid Grid.Row="1" ColumnDefinitions="2*,*,2*">
                    <TextBlock Text="键" FontWeight="SemiBold" Foreground="#64748B" />
                    <TextBlock Grid.Column="1" Text="类型" FontWeight="SemiBold" Foreground="#64748B" />
                    <TextBlock Grid.Column="2" Text="值 / 时间" FontWeight="SemiBold" Foreground="#64748B" />
                  </Grid>
                  <ScrollViewer Grid.Row="2">
                    <ItemsControl ItemsSource="{Binding LatestTelemetry}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:DataValueItem">
                          <Grid ColumnDefinitions="2*,*,2*" Margin="0,0,0,8">
                            <TextBlock Text="{Binding KeyName}" />
                            <TextBlock Grid.Column="1" Text="{Binding DataType}" Foreground="#64748B" />
                            <StackPanel Grid.Column="2">
                              <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding TimestampText}" Foreground="#94A3B8" FontSize="12" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>

              <Border Grid.Column="1" Padding="18" CornerRadius="18" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
                  <TextBlock Text="聚合遥测查询" FontSize="20" FontWeight="Bold" />

                  <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock Text="Keys（逗号分隔）" FontWeight="SemiBold" />
                      <TextBox Text="{Binding TelemetryKeys, Mode=TwoWay}" Watermark="temp,humidity" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="6">
                      <TextBlock Text="Aggregate" FontWeight="SemiBold" />
                      <ComboBox ItemsSource="{Binding AggregateOptions}" SelectedItem="{Binding SelectedAggregate, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Spacing="6">
                      <TextBlock Text="开始时间（ISO）" FontWeight="SemiBold" />
                      <TextBox Text="{Binding TelemetryBeginText, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                      <TextBlock Text="结束时间（ISO）" FontWeight="SemiBold" />
                      <TextBox Text="{Binding TelemetryEndText, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Spacing="6">
                      <TextBlock Text="Every（时间间隔）" FontWeight="SemiBold" />
                      <TextBox Text="{Binding TelemetryEveryText, Mode=TwoWay}" Watermark="00:05:00" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" VerticalAlignment="Bottom">
                      <atom:Button Content="查询遥测 / 聚合数据" Command="{Binding QueryTelemetryCommand}" />
                    </StackPanel>
                  </Grid>

                  <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="12" Padding="10">
                    <TextBlock Text="{Binding TelemetrySummary}" Foreground="#475569" TextWrapping="Wrap" />
                  </Border>

                  <ScrollViewer Grid.Row="3">
                    <ItemsControl ItemsSource="{Binding QueryTelemetryResults}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:DataValueItem">
                          <Grid ColumnDefinitions="2*,*,2*" Margin="0,0,0,8">
                            <TextBlock Text="{Binding KeyName}" />
                            <TextBlock Grid.Column="1" Text="{Binding DataType}" Foreground="#64748B" />
                            <StackPanel Grid.Column="2">
                              <TextBlock Text="{Binding Value}" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding TimestampText}" Foreground="#94A3B8" FontSize="12" />
                            </StackPanel>
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</atom:Window>
